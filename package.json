{
  "name": "pi-inline-format-extensions",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension"
  ],
  "workspaces": [
    "packages/*"
  ],
  "pi": {
    "extensions": [
      "./packages/host/extensions/index.ts"
    ]
  },
  "scripts": {
    "check": "npm run format && npm run typecheck",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.63.1",
    "@types/node": "^25.5.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
